{
  "info": {
    "_postman_id": "openregister-platform-annotations",
    "name": "OpenRegister - Platform Annotations + Integration Providers",
    "description": "End-to-end tests for the four declarative annotations (lifecycle, aggregations, calculations, notifications) and the integration provider routes (contacts/match, actions, emails, references). Verifies the platform foundation that landed in PR #1357 + the migrations across decidesk, docudesk, procest, softwarecatalog, opencatalogi.\n\nRequires:\n- All annotation pilots in place (decidesk Meeting / Motion / Minutes / ActionItem / docudesk signingRequest)\n- admin:admin user\n- baseUrl variable (default http://localhost:8080)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{username}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{password}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "username",
      "value": "admin"
    },
    {
      "key": "password",
      "value": "admin"
    }
  ],
  "item": [
    {
      "name": "Lifecycle — Meeting full path",
      "item": [
        {
          "name": "Create Meeting (draft)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "const j = pm.response.json();",
                  "pm.expect(j.lifecycle).to.eql('draft');",
                  "pm.collectionVariables.set('meetingId', j['@self'].id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\":\"Newman lifecycle test\",\"meetingType\":\"regular\",\"scheduledDate\":\"2026-05-01T10:00:00+02:00\",\"meetingMode\":\"hybrid\",\"lifecycle\":\"draft\"}"
            },
            "url": "{{baseUrl}}/index.php/apps/openregister/api/objects/decidesk/meeting"
          }
        },
        {
          "name": "GET available-actions for draft (expect schedule, withdraw)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const actions = pm.response.json().actions.map(a => a.action);",
                  "pm.expect(actions).to.include('schedule');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/index.php/apps/openregister/api/objects/{{meetingId}}/available-actions"
          }
        },
        {
          "name": "Transition: schedule (draft → scheduled)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.expect(pm.response.json().lifecycle).to.eql('scheduled');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"action\":\"schedule\"}"
            },
            "url": "{{baseUrl}}/index.php/apps/openregister/api/objects/{{meetingId}}/transition"
          }
        },
        {
          "name": "Invalid transition: resume from scheduled (expect 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.expect(pm.response.json().error).to.include('not allowed');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"action\":\"resume\"}"
            },
            "url": "{{baseUrl}}/index.php/apps/openregister/api/objects/{{meetingId}}/transition"
          }
        },
        {
          "name": "Transition: open (guard runs, allowed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.expect(pm.response.json().lifecycle).to.eql('opened');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"action\":\"open\"}"
            },
            "url": "{{baseUrl}}/index.php/apps/openregister/api/objects/{{meetingId}}/transition"
          }
        },
        {
          "name": "Transition: close (terminal)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.expect(pm.response.json().lifecycle).to.eql('closed');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"action\":\"close\"}"
            },
            "url": "{{baseUrl}}/index.php/apps/openregister/api/objects/{{meetingId}}/transition"
          }
        },
        {
          "name": "Cleanup: delete meeting",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/index.php/apps/openregister/api/objects/decidesk/meeting/{{meetingId}}"
          }
        }
      ]
    },
