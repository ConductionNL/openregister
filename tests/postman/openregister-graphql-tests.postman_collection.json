		{
			"name": "10. Mutation type has create/update/delete",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Response is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"var body = pm.response.json();",
							"var fieldNames = body.data.__type.fields.map(f => f.name);",
							"pm.test('Has create mutations', function () {",
							"    var creates = fieldNames.filter(n => n.startsWith('create'));",
							"    pm.expect(creates.length).to.be.above(0);",
							"});",
							"pm.test('Has update mutations', function () {",
							"    var updates = fieldNames.filter(n => n.startsWith('update'));",
							"    pm.expect(updates.length).to.be.above(0);",
							"});",
							"pm.test('Has delete mutations', function () {",
							"    var deletes = fieldNames.filter(n => n.startsWith('delete'));",
							"    pm.expect(deletes.length).to.be.above(0);",
							"});"
						],
						"type": "text/javascript"
					}
				}
