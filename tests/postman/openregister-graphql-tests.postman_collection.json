{
	"info": {
		"name": "OpenRegister GraphQL API Tests",
		"description": "Integration tests for the OpenRegister GraphQL API endpoint.\n\nTests cover: introspection, schema generation, queries, mutations, pagination, filtering, error handling, complexity analysis, and rate limiting.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "basic",
		"basic": [
			{
				"key": "username",
				"value": "{{username}}",
				"type": "string"
			},
			{
				"key": "password",
				"value": "{{password}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost"
		},
		{
			"key": "username",
			"value": "admin"
		},
		{
			"key": "password",
			"value": "admin"
		},
		{
			"key": "test_register_id",
			"value": ""
		},
		{
			"key": "test_schema_id",
			"value": ""
		},
		{
			"key": "test_object_uuid",
			"value": ""
		},
		{
			"key": "test_schema_slug",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Setup: Create Test Register",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Register created (200/201)', function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
							"});",
							"var body = pm.response.json();",
							"pm.collectionVariables.set('test_register_id', body.id || body.data?.id);",
							"pm.test('Register has ID', function () {",
							"    pm.expect(pm.collectionVariables.get('test_register_id')).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"title\": \"Newman GraphQL Test Register\", \"description\": \"Test register for GraphQL Newman tests\", \"schemas\": []}"
				},
				"url": "{{baseUrl}}/index.php/apps/openregister/api/registers"
			}
		},
		{
			"name": "Setup: Create Test Schema",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Schema created (200/201)', function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
							"});",
							"var body = pm.response.json();",
							"pm.collectionVariables.set('test_schema_id', body.id || body.data?.id);",
							"pm.collectionVariables.set('test_schema_slug', body.slug || body.data?.slug);",
							"pm.test('Schema has ID', function () {",
							"    pm.expect(pm.collectionVariables.get('test_schema_id')).to.exist;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"title\": \"Newman GraphQL Meldingen\", \"description\": \"Test schema for GraphQL tests\", \"properties\": {\"title\": {\"type\": \"string\"}, \"status\": {\"type\": \"string\"}, \"priority\": {\"type\": \"integer\"}, \"email\": {\"type\": \"string\", \"format\": \"email\"}}, \"required\": [\"title\"]}"
				},
				"url": "{{baseUrl}}/index.php/apps/openregister/api/schemas"
			}
		},
		{
			"name": "Setup: Link Schema to Register",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Register updated (200)', function () {",
							"    pm.expect(pm.response.code).to.equal(200);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"schemas\": [{{test_schema_id}}]}"
				},
				"url": "{{baseUrl}}/index.php/apps/openregister/api/registers/{{test_register_id}}"
			}
		},
		{
			"name": "1. Introspection: Schema types exist",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Response is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"var body = pm.response.json();",
							"pm.test('Has data field', function () {",
							"    pm.expect(body).to.have.property('data');",
							"});",
							"pm.test('Has __schema with types', function () {",
							"    pm.expect(body.data).to.have.property('__schema');",
							"    pm.expect(body.data.__schema).to.have.property('types');",
							"});",
							"var typeNames = body.data.__schema.types.map(t => t.name);",
							"pm.test('Has Query type', function () {",
							"    pm.expect(typeNames).to.include('Query');",
							"});",
							"pm.test('Has Mutation type', function () {",
							"    pm.expect(typeNames).to.include('Mutation');",
							"});",
							"pm.test('Has PageInfo type', function () {",
							"    pm.expect(typeNames).to.include('PageInfo');",
							"});",
							"pm.test('Has DateTime scalar', function () {",
							"    pm.expect(typeNames).to.include('DateTime');",
							"});",
							"pm.test('Has UUID scalar', function () {",
							"    pm.expect(typeNames).to.include('UUID');",
							"});",
							"pm.test('Has Email scalar', function () {",
							"    pm.expect(typeNames).to.include('Email');",
							"});",
							"pm.test('Has JSON scalar', function () {",
							"    pm.expect(typeNames).to.include('JSON');",
							"});",
							"pm.test('Has AuditTrailEntry type', function () {",
							"    pm.expect(typeNames).to.include('AuditTrailEntry');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"query\": \"{ __schema { types { name } } }\"}"
				},
				"url": "{{baseUrl}}/index.php/apps/openregister/api/graphql"
			}
		},
		{
			"name": "2. Complexity info in extensions",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Response is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"var body = pm.response.json();",
							"pm.test('Has extensions.complexity', function () {",
							"    pm.expect(body).to.have.property('extensions');",
							"    pm.expect(body.extensions).to.have.property('complexity');",
							"});",
							"pm.test('Complexity has expected fields', function () {",
							"    var c = body.extensions.complexity;",
							"    pm.expect(c).to.have.property('estimated');",
							"    pm.expect(c).to.have.property('max');",
							"    pm.expect(c).to.have.property('depth');",
							"    pm.expect(c).to.have.property('maxDepth');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"query\": \"{ __schema { queryType { name } } }\"}"
				},
				"url": "{{baseUrl}}/index.php/apps/openregister/api/graphql"
			}
		},
		{
			"name": "3. Invalid query returns error",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Response is 400', function () {",
							"    pm.response.to.have.status(400);",
							"});",
							"var body = pm.response.json();",
							"pm.test('Has errors array', function () {",
							"    pm.expect(body).to.have.property('errors');",
							"    pm.expect(body.errors).to.be.an('array').that.is.not.empty;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"query\": \"{ thisFieldDoesNotExist }\"}"
				},
				"url": "{{baseUrl}}/index.php/apps/openregister/api/graphql"
			}
		},
		{
			"name": "4. Missing query field returns 400",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Response is 400', function () {",
							"    pm.response.to.have.status(400);",
							"});",
							"var body = pm.response.json();",
							"pm.test('Error mentions query field', function () {",
							"    pm.expect(body.errors[0].message).to.include('query');",
							"});",
							"pm.test('Error code is BAD_REQUEST', function () {",
							"    pm.expect(body.errors[0].extensions.code).to.equal('BAD_REQUEST');",
							"});"
						],
						"type": "text/javascript"
					}
				}
