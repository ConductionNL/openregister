		{
			"name": "8. Connection type has edges and pageInfo",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Response is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"var body = pm.response.json();",
							"var types = body.data.__schema.types;",
							"var connectionTypes = types.filter(t => t.name.endsWith('Connection'));",
							"pm.test('Has at least one Connection type', function () {",
							"    pm.expect(connectionTypes.length).to.be.above(0);",
							"});",
							"var conn = connectionTypes[0];",
							"var fieldNames = conn.fields.map(f => f.name);",
							"pm.test('Connection has edges', function () { pm.expect(fieldNames).to.include('edges'); });",
							"pm.test('Connection has pageInfo', function () { pm.expect(fieldNames).to.include('pageInfo'); });",
							"pm.test('Connection has totalCount', function () { pm.expect(fieldNames).to.include('totalCount'); });",
							"pm.test('Connection has facets', function () { pm.expect(fieldNames).to.include('facets'); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"query\": \"{ __schema { types { name fields { name } } } }\"}"
				},
				"url": "{{baseUrl}}/index.php/apps/openregister/api/graphql"
			}
		},
