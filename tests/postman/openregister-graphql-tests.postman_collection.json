							"pm.test('Has hasPreviousPage', function () { pm.expect(fields).to.include('hasPreviousPage'); });",
							"pm.test('Has startCursor', function () { pm.expect(fields).to.include('startCursor'); });",
							"pm.test('Has endCursor', function () { pm.expect(fields).to.include('endCursor'); });"
