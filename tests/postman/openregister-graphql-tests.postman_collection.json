		{
			"name": "6. PageInfo type has required fields",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Response is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"var body = pm.response.json();",
