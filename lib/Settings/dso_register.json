        "type": "object",
        "required": [
          "identificatie",
          "type",
          "titel"
        ],
        "properties": {
          "identificatie": {
            "type": "string",
            "description": "Unique document identifier"
          },
          "type": {
            "type": "string",
            "description": "Type of environmental document",
            "enum": [
              "omgevingsplan",
              "omgevingsverordening",
              "waterschapsverordening",
              "AMvB",
              "ministeriele_regeling"
            ]
          },
          "status": {
            "type": "string",
            "description": "Publication status of the document",
            "enum": [
              "vastgesteld",
              "ontwerp",
              "ingetrokken"
            ]
          },
          "bevoegdGezag": {
            "type": "string",
            "description": "Competent authority (organization name or OIN)"
          },
          "titel": {
            "type": "string",
            "description": "Title of the document"
          },
          "publicatiedatum": {
            "type": "string",
            "format": "date",
            "description": "Date of publication"
          }
        },
        "hardValidation": false,
        "searchable": true
      },
      "vergunningaanvraag": {
        "slug": "vergunningaanvraag",
        "title": "Vergunningaanvraag",
        "version": "1.0.0",
        "published": "2025-01-01T00:00:00+00:00",
        "summary": "An environmental permit application",
        "description": "Permit applications represent requests submitted through the DSO Omgevingsloket. They reference one or more activities and a location, and track the application lifecycle from submission through decision.",
        "type": "object",
        "required": [
          "identificatie",
          "activiteiten",
          "locatie",
          "status",
          "indieningsdatum"
        ],
        "properties": {
          "identificatie": {
            "type": "string",
            "description": "Unique application identifier"
          },
          "activiteiten": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "References to the activities in this application"
          },
          "locatie": {
            "type": "object",
            "description": "Application location",
            "properties": {
              "identificatie": {
                "type": "string",
                "description": "Reference to a locatie record"
              },
              "adres": {
                "type": "string",
                "description": "Human-readable address"
              }
            }
          },
          "initiatiefnemer": {
            "type": "object",
            "description": "Applicant details",
            "properties": {
              "naam": {
                "type": "string",
                "description": "Applicant name"
              },
              "type": {
                "type": "string",
                "description": "Type of applicant",
                "enum": [
                  "particulier",
                  "bedrijf"
                ]
              }
            }
          },
          "bevoegdGezag": {
            "type": "string",
            "description": "Competent authority handling the application"
          },
          "status": {
            "type": "string",
            "description": "Current status of the application",
            "enum": [
              "ingediend",
              "in_behandeling",
              "verleend",
              "geweigerd",
              "ingetrokken"
            ]
          },
          "indieningsdatum": {
            "type": "string",
            "format": "date",
            "description": "Date the application was submitted"
          },
          "besluitdatum": {
            "type": "string",
            "format": "date",
            "description": "Date the decision was made"
          },
          "bijlagen": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "naam": {
                  "type": "string",
                  "description": "Attachment file name"
                },
                "type": {
                  "type": "string",
                  "description": "Attachment type"
                }
              }
            },
            "description": "Attachments to the application"
          },
          "toelichting": {
            "type": "string",
            "description": "Additional explanation or decision motivation"
          }
        },
        "hardValidation": false,
        "searchable": true
      }
