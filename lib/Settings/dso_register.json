        "slug": "activiteit",
        "title": "Activiteit",
        "version": "1.0.0",
        "published": "2025-01-01T00:00:00+00:00",
        "summary": "An activity within the DSO environment and planning system",
        "description": "Activities represent regulated actions under the Omgevingswet, such as construction, demolition, tree felling, or environmental operations. Each activity has a classification (regelkwalificatie) indicating whether it requires a permit, notification, or is permit-free. Activities can form a hierarchy via bovenliggendeActiviteit.",
        "type": "object",
        "required": [
          "identificatie",
          "naam",
          "regelkwalificatie"
        ],
        "properties": {
          "identificatie": {
            "type": "string",
            "description": "Unique identifier for the activity"
          },
          "naam": {
            "type": "string",
            "description": "Name of the activity (e.g. 'Dakkapel plaatsen')"
          },
          "activiteitgroep": {
            "type": "string",
            "description": "Category group the activity belongs to"
          },
          "regelkwalificatie": {
            "type": "string",
            "description": "Regulatory classification of the activity",
            "enum": [
              "vergunningplicht",
              "meldingsplicht",
              "informatieplicht",
              "vergunningvrij"
            ]
          },
          "bovenliggendeActiviteit": {
            "type": "string",
            "description": "Reference to the parent activity in the hierarchy"
          },
          "omschrijving": {
            "type": "string",
            "description": "Detailed description of the activity"
          }
        },
        "hardValidation": false,
        "searchable": true
      },
      "locatie": {
