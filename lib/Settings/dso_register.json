        "description": "Locations represent geographic areas or addresses relevant to environmental permits and regulations. They can reference specific BAG addresses or represent broader municipal areas.",
        "type": "object",
        "required": [
          "identificatie",
          "naam",
          "type"
        ],
        "properties": {
          "identificatie": {
            "type": "string",
