{
  "openapi": "3.0.0",
  "info": {
    "title": "KVK Mock Register",
    "description": "Mock KVK (Kamer van Koophandel) register with Disney-themed test data from the official KVK test environment, supplemented with realistic fictional Dutch businesses.",
    "version": "1.0.0"
  },
  "x-openregister": {
    "type": "mock",
    "app": "openregister",
    "openregister": "^v0.2.10",
    "description": "KVK mock register for development and testing — enables Pipelinq, Procest and other apps to develop business integrations without KVK API credentials"
  },
  "paths": {},
  "components": {
    "registers": {
      "kvk": {
        "slug": "kvk",
        "title": "KVK (Kamer van Koophandel)",
        "description": "Mock Handelsregister with fictional business records aligned to the KVK API data model. Contains Disney-themed test companies from the official KVK test environment and additional realistic Dutch businesses covering diverse legal forms, sectors, and provinces.",
        "schemas": [
          "maatschappelijke-activiteit",
          "vestiging"
        ],
        "folder": "Open Registers/KVK"
      }
    },
    "schemas": {
      "maatschappelijke-activiteit": {
        "slug": "maatschappelijke-activiteit",
        "title": "Maatschappelijke Activiteit",
        "version": "1.0.0",
        "published": "2026-01-01T00:00:00+00:00",
        "summary": "A business entity registered at the Chamber of Commerce",
        "description": "Represents a maatschappelijke activiteit (business entity) in the KVK Handelsregister. Each record corresponds to a unique KVK number and contains the legal form, trade names, SBI activity codes, employee count, and registration dates.",
        "required": [
          "kvkNummer",
          "naam"
        ],
        "properties": {
          "kvkNummer": {
            "type": "string",
            "description": "8-digit KVK registration number",
            "pattern": "^\\d{8}$",
            "minLength": 8,
            "maxLength": 8,
            "facetable": true
          },
          "naam": {
            "type": "string",
            "description": "Primary name of the business",
            "maxLength": 255,
            "facetable": true
          },
          "handelsnamen": {
            "type": "array",
            "description": "Trade names with ordering",
            "items": {
              "type": "object",
              "properties": {
                "naam": {
                  "type": "string",
                  "description": "Trade name"
                },
                "volgorde": {
                  "type": "integer",
                  "description": "Display order (0 = primary)"
                }
              },
              "required": ["naam", "volgorde"]
            },
            "facetable": false
          },
          "rechtsvorm": {
            "type": "string",
            "description": "Legal form description",
            "facetable": true
          },
          "uitgebreideRechtsvorm": {
            "type": "string",
            "description": "Detailed legal form description",
            "facetable": false
          },
          "formeleRegistratiedatum": {
            "type": "string",
            "description": "Formal registration date (ISO 8601)",
            "format": "date",
            "facetable": false
          },
          "materieleRegistratie": {
            "type": "object",
            "description": "Material registration dates",
            "properties": {
              "datumAanvang": {
                "type": "string",
                "description": "Start date of material registration",
                "format": "date"
              },
              "datumEinde": {
                "type": "string",
                "description": "End date of material registration (null if active)",
                "format": "date"
              }
            },
            "facetable": false
          },
          "totaalWerkzamePersonen": {
            "type": "integer",
            "description": "Total number of employed persons",
            "minimum": 0,
            "facetable": true
          },
          "sbiActiviteiten": {
            "type": "array",
            "description": "SBI (Standaard Bedrijfsindeling) activity codes",
            "items": {
              "type": "object",
              "properties": {
                "sbiCode": {
                  "type": "string",
                  "description": "SBI code"
                },
                "sbiOmschrijving": {
                  "type": "string",
                  "description": "SBI activity description"
                },
                "indHoofdactiviteit": {
                  "type": "string",
                  "description": "Whether this is the main activity (Ja/Nee)",
                  "enum": ["Ja", "Nee"]
                }
              },
              "required": ["sbiCode", "sbiOmschrijving", "indHoofdactiviteit"]
            },
            "facetable": false
          },
          "indNonMailing": {
            "type": "string",
            "description": "Non-mailing indicator (Ja/Nee)",
            "enum": ["Ja", "Nee"],
            "facetable": false
          },
          "actief": {
            "type": "boolean",
            "description": "Whether the business is currently active (computed from datumEinde)",
            "facetable": true
          }
        },
        "hardValidation": false,
        "searchable": true,
        "authorization": {
          "read": ["public"]
        }
      },
      "vestiging": {
        "slug": "vestiging",
        "title": "Vestiging",
        "version": "1.0.0",
        "published": "2026-01-01T00:00:00+00:00",
        "summary": "A branch/establishment of a business",
        "description": "Represents a vestiging (branch/establishment) in the KVK Handelsregister. Each vestiging has a unique 12-digit vestigingsnummer and is linked to a parent business via kvkNummer. Contains address information, employee counts, and SBI activity codes.",
        "required": [
          "vestigingsnummer",
          "kvkNummer",
          "eersteHandelsnaam"
        ],
        "properties": {
          "vestigingsnummer": {
            "type": "string",
            "description": "12-digit branch number",
            "pattern": "^\\d{12}$",
            "minLength": 12,
            "maxLength": 12,
            "facetable": true
          },
          "kvkNummer": {
            "type": "string",
            "description": "8-digit KVK number of the parent business",
            "pattern": "^\\d{8}$",
            "facetable": true
          },
          "eersteHandelsnaam": {
            "type": "string",
            "description": "Primary trade name of the branch",
            "maxLength": 255,
            "facetable": true
          },
          "indHoofdvestiging": {
            "type": "string",
            "description": "Whether this is the main branch (Ja/Nee)",
            "enum": ["Ja", "Nee"],
            "facetable": true
          },
          "indCommercieleVestiging": {
            "type": "string",
            "description": "Whether this is a commercial branch (Ja/Nee)",
            "enum": ["Ja", "Nee"],
            "facetable": false
          },
          "voltijdWerkzamePersonen": {
            "type": "integer",
            "description": "Number of full-time employees",
            "minimum": 0,
            "facetable": false
          },
          "deeltijdWerkzamePersonen": {
            "type": "integer",
            "description": "Number of part-time employees",
            "minimum": 0,
            "facetable": false
          },
          "totaalWerkzamePersonen": {
            "type": "integer",
            "description": "Total number of employees at this branch",
            "minimum": 0,
            "facetable": true
          },
          "adressen": {
            "type": "array",
            "description": "Addresses of the branch (bezoekadres, correspondentieadres)",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Address type",
                  "enum": ["bezoekadres", "correspondentieadres"]
                },
                "straatnaam": {
                  "type": "string",
                  "description": "Street name"
                },
                "huisnummer": {
                  "type": "integer",
                  "description": "House number"
                },
                "huisletter": {
                  "type": "string",
                  "description": "House letter (optional)"
                },
                "postbusnummer": {
                  "type": "integer",
                  "description": "PO box number (optional)"
                },
                "postcode": {
                  "type": "string",
                  "description": "Postal code (####XX)"
                },
                "plaats": {
                  "type": "string",
                  "description": "City"
                },
                "land": {
                  "type": "string",
                  "description": "Country"
                }
              },
              "required": ["type"]
            },
            "facetable": false
          },
          "handelsnamen": {
            "type": "array",
            "description": "Trade names of the branch",
            "items": {
              "type": "object",
              "properties": {
                "naam": {
                  "type": "string",
                  "description": "Trade name"
                },
                "volgorde": {
                  "type": "integer",
                  "description": "Display order"
                }
              },
              "required": ["naam", "volgorde"]
            },
            "facetable": false
          },
          "sbiActiviteiten": {
            "type": "array",
            "description": "SBI activity codes for this branch",
            "items": {
              "type": "object",
              "properties": {
                "sbiCode": {
                  "type": "string"
                },
                "sbiOmschrijving": {
                  "type": "string"
                },
                "indHoofdactiviteit": {
                  "type": "string",
                  "enum": ["Ja", "Nee"]
                }
              },
              "required": ["sbiCode", "sbiOmschrijving", "indHoofdactiviteit"]
            },
            "facetable": false
          }
        },
        "hardValidation": false,
        "searchable": true,
        "authorization": {
          "read": ["public"]
        }
      }
    },
