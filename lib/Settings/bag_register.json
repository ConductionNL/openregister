{
  "openapi": "3.0.0",
  "info": {
    "title": "BAG Mock Register",
    "description": "Mock BAG (Basisregistratie Adressen en Gebouwen) register with realistic Dutch address and building data from PDOK",
    "version": "1.0.0"
  },
  "x-openregister": {
    "type": "mock",
    "app": "openregister",
    "openregister": "^v0.2.10",
    "description": "BAG mock register for development and testing — addresses and buildings aligned with BRP and KVK mock data"
  },
  "paths": {},
  "components": {
    "registers": {
      "bag": {
        "slug": "bag",
        "title": "BAG (Basisregistratie Adressen en Gebouwen)",
        "description": "Mock BAG register containing nummeraanduidingen (addresses), verblijfsobjecten (dwelling units), and panden (buildings) for Dutch municipalities. Data is cross-referenced with the BRP and KVK mock registers.",
        "schemas": [
          "nummeraanduiding",
          "verblijfsobject",
          "pand"
        ],
        "folder": "Open Registers/BAG"
      }
    },
    "schemas": {
      "nummeraanduiding": {
        "slug": "nummeraanduiding",
        "title": "Nummeraanduiding",
        "version": "0.1.0",
        "published": "2025-01-01T00:00:00+00:00",
        "summary": "A BAG address designation (house number + postal code combination)",
        "description": "A nummeraanduiding is the official BAG object that assigns a house number (with optional letter and addition) and postal code to an addressable object. It links a human-readable address to a verblijfsobject, standplaats, or ligplaats via the BAG identification system.",
        "required": [
          "identificatie",
          "huisnummer",
          "postcode",
          "openbareRuimteNaam",
          "woonplaatsNaam",
          "status",
          "typeAdresseerbaarObject"
        ],
        "properties": {
          "identificatie": {
            "type": "string",
            "description": "BAG identification number (16 digits: GGGGTTNNNNNNNNNN, TT=20 for nummeraanduiding)",
            "pattern": "^[0-9]{16}$",
            "minLength": 16,
            "maxLength": 16,
            "facetable": true
          },
          "huisnummer": {
            "type": "integer",
            "description": "House number (1-99999)",
            "minimum": 1,
            "maximum": 99999,
            "facetable": true
          },
          "huisletter": {
            "type": "string",
            "description": "Optional letter suffix (a-z, A-Z)",
            "maxLength": 1,
            "facetable": false
          },
          "huisnummertoevoeging": {
            "type": "string",
            "description": "Optional house number addition (e.g. 'bis', 'I', 'M')",
            "maxLength": 4,
            "facetable": false
          },
          "postcode": {
            "type": "string",
            "description": "Dutch postal code (4 digits + 2 letters)",
            "pattern": "^[0-9]{4}[A-Z]{2}$",
            "minLength": 6,
            "maxLength": 6,
            "facetable": true
          },
          "status": {
            "type": "string",
            "description": "Current BAG status of the nummeraanduiding",
            "enum": [
              "Naamgeving uitgegeven",
              "Naamgeving ingetrokken"
            ],
            "facetable": true
          },
          "typeAdresseerbaarObject": {
            "type": "string",
            "description": "Type of addressable object this nummeraanduiding is assigned to",
            "enum": [
              "Verblijfsobject",
              "Standplaats",
              "Ligplaats"
            ],
            "facetable": true
          },
          "openbareRuimteNaam": {
            "type": "string",
            "description": "Street name (naam openbare ruimte)",
            "maxLength": 80,
            "facetable": true
          },
          "woonplaatsNaam": {
            "type": "string",
            "description": "City or village name",
            "maxLength": 80,
            "facetable": true
          }
        },
        "hardValidation": false,
        "searchable": true,
        "authorization": {
          "read": [
            "public"
          ]
        }
      },
      "verblijfsobject": {
        "slug": "verblijfsobject",
        "title": "Verblijfsobject",
        "version": "0.1.0",
        "published": "2025-01-01T00:00:00+00:00",
        "summary": "A BAG dwelling unit or usable space within a building",
        "description": "A verblijfsobject is the smallest usable unit within one or more panden (buildings) that is suitable for residential, office, retail, or other use. It has one or more gebruiksdoelen (usage purposes) and a floor area in square meters.",
        "required": [
          "identificatie",
          "gebruiksdoel",
          "oppervlakte",
          "status",
          "pandIdentificatie",
          "nummeraanduidingIdentificatie"
        ],
        "properties": {
          "identificatie": {
            "type": "string",
            "description": "BAG identification number (16 digits: GGGGTTNNNNNNNNNN, TT=01 for verblijfsobject)",
            "pattern": "^[0-9]{16}$",
            "minLength": 16,
            "maxLength": 16,
            "facetable": true
          },
          "gebruiksdoel": {
            "type": "array",
            "description": "One or more usage purposes for this dwelling unit",
            "items": {
              "type": "string",
              "enum": [
                "woonfunctie",
                "bijeenkomstfunctie",
                "celfunctie",
                "gezondheidszorgfunctie",
                "industriefunctie",
                "kantoorfunctie",
                "logiesfunctie",
                "onderwijsfunctie",
                "sportfunctie",
                "winkelfunctie",
                "overige gebruiksfunctie"
              ]
            },
            "facetable": true
          },
          "oppervlakte": {
            "type": "integer",
            "description": "Floor area in square meters",
            "minimum": 1,
            "facetable": true
          },
          "status": {
            "type": "string",
            "description": "Current BAG status of the verblijfsobject",
            "enum": [
              "Verblijfsobject in gebruik",
              "Verblijfsobject in gebruik (niet ingemeten)",
              "Verblijfsobject gevormd",
              "Verblijfsobject ingetrokken",
              "Verblijfsobject buiten gebruik"
            ],
            "facetable": true
          },
          "pandIdentificatie": {
            "type": "string",
            "description": "Reference to the pand (building) this verblijfsobject is in (16 digits, TT=10)",
            "pattern": "^[0-9]{16}$",
            "facetable": true
          },
          "nummeraanduidingIdentificatie": {
            "type": "string",
            "description": "Reference to the nummeraanduiding (address) of this verblijfsobject (16 digits, TT=20)",
            "pattern": "^[0-9]{16}$",
            "facetable": true
          }
        },
        "hardValidation": false,
        "searchable": true,
        "authorization": {
          "read": [
            "public"
          ]
        }
      },
      "pand": {
        "slug": "pand",
        "title": "Pand",
        "version": "0.1.0",
        "published": "2025-01-01T00:00:00+00:00",
        "summary": "A BAG building (pand)",
        "description": "A pand is the smallest building unit that is architecturally self-contained, accessible from the outside, and functionally independent. Each pand has a construction year and a status indicating its lifecycle state.",
        "required": [
          "identificatie",
          "oorspronkelijkBouwjaar",
          "status"
        ],
        "properties": {
          "identificatie": {
            "type": "string",
            "description": "BAG identification number (16 digits: GGGGTTNNNNNNNNNN, TT=10 for pand)",
            "pattern": "^[0-9]{16}$",
            "minLength": 16,
            "maxLength": 16,
            "facetable": true
          },
          "oorspronkelijkBouwjaar": {
            "type": "string",
            "description": "Original construction year (4 digits)",
            "pattern": "^[0-9]{4}$",
            "minLength": 4,
            "maxLength": 4,
            "facetable": true
          },
          "status": {
            "type": "string",
            "description": "Current BAG status of the pand",
            "enum": [
              "Pand in gebruik",
              "Pand in gebruik (niet ingemeten)",
              "Pand gesloopt",
              "Bouwvergunning verleend",
              "Niet gerealiseerd pand",
              "Pand buiten gebruik",
              "Bouw gestart",
              "Sloopvergunning verleend"
            ],
            "facetable": true
          }
        },
        "hardValidation": false,
        "searchable": true,
        "authorization": {
          "read": [
            "public"
          ]
        }
      }
    },
